# 忽略巨大的依賴套件
node_modules/

# 忽略編譯產生的檔案
dist/
.output/
.nuxt/

# 忽略環境變數設定
.env
.env.prod
nginx/ssl/

# 忽略系統產生的垃圾檔
.DS_Store
Thumbs.db

# 忽略 Log 紀錄檔
*.log

# 忽略 Docker 資料庫的本地存檔
postgres_data/
minio_data/

# npm workspaces：lock file 統一由根目錄管理
# 子目錄不應有自己的 package-lock.json
backend/package-lock.json
frontend-client/package-lock.json
frontend-admin/package-lock.json
shared/package-lock.json