# ============================================================
# Smart Market 生產環境變數範本
# 複製此檔案為 .env.prod 並填入真實值
# 注意：.env.prod 已加入 .gitignore，不會被 commit
# ============================================================

# ----------------------------
# PostgreSQL
# ----------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=smart_market
DB_HOST=sm_db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me_strong_password
DB_NAME=smart_market

# ----------------------------
# MinIO (圖片儲存)
# ----------------------------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change_me_strong_password
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=change_me_strong_password
MINIO_BUCKET=images
# 前端存取圖片的公開 URL（Nginx 代理 MinIO）
MINIO_PUBLIC_URL=https://panda-map.com/minio

# ----------------------------
# Backend (NestJS)
# ----------------------------
NODE_ENV=production
PORT=8080
JWT_SECRET=change_me_very_long_random_string_at_least_32_chars
JWT_EXPIRATION=1d
# CORS 允許的前端網域（多個用逗號分隔）
CORS_ORIGINS=https://panda-map.com

# ----------------------------
# OAuth - Google
# （在 Google Cloud Console 更新 Authorized redirect URIs）
# ----------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://panda-map.com/api/auth/google/callback

# ----------------------------
# OAuth - LINE
# （在 LINE Developers Console 更新 Callback URL）
# ----------------------------
LINE_CHANNEL_ID=your_line_channel_id
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CALLBACK_URL=https://panda-map.com/api/auth/line/callback

# ----------------------------
# Nuxt Frontend
# （NUXT_ 前綴讓 Nuxt 在 runtime 自動讀取）
# ----------------------------
NUXT_PUBLIC_API_BASE=https://panda-map.com/api

# ----------------------------
# Admin Frontend
# （VITE_ 是 build-time 變數，設在 docker-compose.prod.yml args）
# ----------------------------
VITE_API_BASE=https://panda-map.com/api

# ----------------------------
# Gemini AI
# ----------------------------
GEMINI_API_KEY=your_gemini_api_key
