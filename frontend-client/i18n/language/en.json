    "q1": {
      "title": "How does Creative Corner work?",
      "p1": "It's simple! Think of it like a giant online art class swap. You can list your old toys...",
      "p2": "Parents help with the payment and shipping part to keep everything safe and sound...",
      "read_more": "Read more details"
    },
    "super_easy": "Super Easy!",
    "still_have_questions": "Still have questions?",
    "ready_to_help": "Our team is ready to help you out!",
    "contact_support": "Contact Support",
    "answers": {
      "general": {
        "title": "How does the platform work?",
        "p1": "Think of it as a giant online swap market! You can list your unused toys or clothes for sale, or find treasures from other sellers.",
        "p2": "All transactions are protected by the platform to ensure safe trading for both buyers and sellers. Just register an account to get started."
      },
      "buying": {
        "title": "How to buy items?",
        "p1": "When you see an item you like on the homepage or item list, click into the detail page. If it's in stock and not listed by you, you can add it to your cart.",
        "p2": "Go to the cart and click checkout. You can choose secure online ECPay or Cash on Delivery. After payment, just wait for the seller to ship!"
      },
      "selling": {
        "title": "How do I start selling?",
        "p1": "Click 'Post Item' in the account menu, upload clear pictures, fill in the condition, price, and description, and the system will list it for you immediately.",
        "p2": "When a buyer places an order, you will see it in 'My Orders (Seller)'. Click 'Confirm Shipment' after sending the item to let the buyer track the shipping status."
      },
      "safety": {
        "title": "Are transactions safe?",
        "p1": "Absolutely safe! We use certified third-party payment gateways (like ECPay) to protect your credit card and account information.",
        "p2": "Funds are held in escrow by the system until the buyer clicks 'Confirm Receipt'. If the item doesn't match the description, contact customer support for a refund."
      },
      "shipping": {
        "title": "Shipping fees and methods?",
        "p1": "The platform currently provides standard home delivery service. Shipping fees will be automatically calculated on the checkout page based on the order total.",
        "p2": "Sellers should securely package and ship the item using a trusted logistics provider within three working days after the buyer's payment, then click ship on the platform."
      }
    }
  },
